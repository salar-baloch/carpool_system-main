// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String   @unique
  password       String
  driverLicense  String
  phone          String?
  country        String?
  dateOfBirth    DateTime?
  gender         String
  shares         Share[]  // Relation to Share table
  requests       Request[] // Relation to Request table
  documents      Document[]
  messages       Message[]
  ratingsGiven   Rating[]  @relation("RaterRelation")
  ratingsReceived Rating[] @relation("RateeRelation")
  notifications  Notification[]
  isVerified     Boolean  @default(false)
}

enum DocumentType {
  DRIVER_LICENSE_FRONT
  DRIVER_LICENSE_BACK
  CNIC_FRONT
  CNIC_BACK
  VEHICLE_REGISTRATION
  PROFILE_PICTURE
  PROOF_OF_ADDRESS
}

model Document {
  id           Int          @id @default(autoincrement())
  userId       Int
  type         DocumentType
  originalName String
  mimeType     String
  size         Int
  storagePath  String
  createdAt    DateTime     @default(now())
  status       DocumentStatus @default(PENDING)
  verifiedAt   DateTime?
  verifiedBy   String?
  rejectReason String?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

model OtpCode {
  id         Int      @id @default(autoincrement())
  phone      String
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime @default(now())
}

model Share {
  id              Int      @id @default(autoincrement())
  driverId        Int
  origin          String
  destination     String
  departureTime   DateTime
  spots           Int
  message         String?
  contactNumber   String?
  price           Float?

  driver          User     @relation(fields: [driverId], references: [id])
  requests        Request[] // Relation to Request table
}

model Request {
  id             Int      @id @default(autoincrement())
  shareId        Int
  userId         Int
  message        String?
  status         RequestStatus @default(PENDING)
  createdAt      DateTime @default(now())

  share          Share    @relation(fields: [shareId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  messages       Message[]
  ratings        Rating[]
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
}

model Message {
  id         Int      @id @default(autoincrement())
  requestId  Int
  senderId   Int
  text       String
  createdAt  DateTime @default(now())

  request    Request  @relation(fields: [requestId], references: [id])
  sender     User     @relation(fields: [senderId], references: [id])
}

model Rating {
  id         Int      @id @default(autoincrement())
  requestId  Int
  raterId    Int
  rateeId    Int
  score      Int
  comment    String?
  createdAt  DateTime @default(now())

  request    Request  @relation(fields: [requestId], references: [id])
  rater      User     @relation("RaterRelation", fields: [raterId], references: [id])
  ratee      User     @relation("RateeRelation", fields: [rateeId], references: [id])

  @@unique([requestId, raterId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  createdAt DateTime @default(now())
  readAt    DateTime?

  user      User     @relation(fields: [userId], references: [id])
}

